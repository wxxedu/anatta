# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Coverage / profiling artifacts
*.profraw
tarpaulin-report.html
lcov.info

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# ── Editors ──────────────────────────────────────────────────────────────
.vscode/
*.swp
*.swo
*~

# ── OS junk ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Local env / secrets ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
.envrc.local

# ── anatta local dev state (when ANATTA_HOME points inside the repo) ─────
/.anatta/
/.anatta-*/

# ── Claude Code session state ────────────────────────────────────────────
# Worktrees that EnterWorktree creates land here; they're per-session,
# not source-controlled.
.claude/

# ── Stray sqlx offline cache at repo root ────────────────────────────────
# The real one lives at crates/anatta-store/.sqlx/; running `cargo sqlx
# prepare` from the repo root accidentally dumps a second copy here.
/.sqlx/
